<Window x:Class="WebScreenCapture.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Screen Capture"
        Width="1120"
        Height="720"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Icon="app.ico"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
  <Grid>
    <Grid x:Name="SetupPanel" Background="{StaticResource BackgroundBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.2*" />
        <ColumnDefinition Width="0.8*" MinWidth="360" />
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0">
        <Grid.Background>
          <RadialGradientBrush Center="0.28,0.3" GradientOrigin="0.28,0.3" RadiusX="0.78" RadiusY="0.78">
            <GradientStop Color="#274239" Offset="0" />
            <GradientStop Color="#101417" Offset="0.54" />
            <GradientStop Color="#0C0E10" Offset="1" />
          </RadialGradientBrush>
        </Grid.Background>
        <StackPanel Margin="64" VerticalAlignment="Bottom">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,72">
            <Image Source="Assets/logo-mark.png" Width="28" Height="28" Margin="0,0,10,0" />
            <TextBlock Text="S C R E E N" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock Text="C A P T U R E   A G E N T" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="Bold" Margin="0,0,0,18" />
          <TextBlock Text="把桌面，&#x0a;送到另一块屏幕。" FontSize="58" FontWeight="SemiBold" LineHeight="60" TextWrapping="Wrap" />
          <TextBlock Text="端到端 WebRTC。服务器只建立连接，不保存你的画面。" Foreground="#A2AAA6" FontSize="14" Margin="0,24,0,0" />
        </StackPanel>
      </Grid>

      <StackPanel Grid.Column="1" Margin="54" VerticalAlignment="Center">
        <TextBlock Text="连接设置" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,34" />

        <TextBlock Text="服务器地址" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,7" />
        <TextBox x:Name="ServerUrlInput" Text="https://screen.flyingrtx.com" Margin="0,0,0,24" />

        <TextBlock Text="访问 Token" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,7" />
        <PasswordBox x:Name="AccessTokenInput" Margin="0,0,0,10" />
        <TextBlock Text="与网页使用同一个 Token，并通过 Windows DPAPI 加密保存。" Foreground="#68706C" FontSize="11" Margin="0,0,0,30" />

        <Button x:Name="SaveButton" Content="连接捕获服务" Height="50" Background="{StaticResource AccentBrush}" Foreground="#07110D" BorderThickness="0" FontSize="13" FontWeight="Bold" Cursor="Hand" Click="SaveButton_Click" />
        <TextBlock x:Name="SetupError" Foreground="#FF776F" FontSize="12" TextWrapping="Wrap" MinHeight="20" Margin="0,12,0,0" />
        <Button x:Name="WebView2InstallButton" Content="安装 Microsoft WebView2 Runtime" Visibility="Collapsed" Height="42" Margin="0,8,0,0" Background="#202725" Foreground="{StaticResource TextBrush}" BorderBrush="#3A4541" Cursor="Hand" Click="WebView2InstallButton_Click" />

        <TextBlock Margin="0,28,0,0" Foreground="#68706C" FontSize="11" TextWrapping="Wrap">
          启动捕获时 Windows 会显示屏幕选择窗口。程序不会在后台静默选择屏幕。
        </TextBlock>
      </StackPanel>
    </Grid>

    <Grid x:Name="BrowserPanel" Visibility="Collapsed">
      <wv2:WebView2 x:Name="AgentWebView" DefaultBackgroundColor="#08090B" />
    </Grid>
  </Grid>
</Window>
