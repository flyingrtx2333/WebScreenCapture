<Window x:Class="WebScreenCapture.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Capture 2.0"
        Width="640"
        Height="570"
        MinWidth="600"
        MinHeight="540"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Icon="app.ico"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
  <Grid Margin="30,24,30,26">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" Margin="0,0,0,26">
      <Border DockPanel.Dock="Left" Width="46" Height="46" CornerRadius="10" Background="#17251F" Margin="0,0,14,0">
        <Image Source="Assets/logo-mark.png" Width="27" Height="27" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>
      <Border DockPanel.Dock="Right" Padding="9,5" CornerRadius="12" BorderBrush="#2D3833" BorderThickness="1" VerticalAlignment="Center">
        <TextBlock Text="NATIVE 2.0" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold" />
      </Border>
      <StackPanel VerticalAlignment="Center">
        <TextBlock Text="桌面捕获器" FontSize="21" FontWeight="SemiBold" />
        <TextBlock Text="DXGI 整桌面捕获 · NVIDIA NVENC" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,5,0,0" />
      </StackPanel>
    </DockPanel>

    <Grid Grid.Row="1" Margin="0,0,0,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="88" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <TextBlock Text="服务器" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" />
      <TextBox x:Name="ServerUrlInput" Grid.Column="1" Text="https://screen.flyingrtx.com" />
    </Grid>

    <Grid Grid.Row="2" Margin="0,0,0,23">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="88" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <TextBlock Text="配对 Token" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" />
      <TextBox x:Name="PairingTokenInput" Grid.Column="1" MaxLength="256" />
    </Grid>

    <Grid Grid.Row="3" Margin="0,0,0,22">
      <Button x:Name="StartButton"
              Content="开始捕获整个桌面"
              Height="48"
              Background="{StaticResource AccentBrush}"
              Foreground="#07110D"
              BorderThickness="0"
              FontSize="13"
              FontWeight="Bold"
              Cursor="Hand"
              Click="StartButton_Click" />
      <Button x:Name="StopButton"
              Content="停止捕获"
              Height="48"
              Background="#282E2B"
              Foreground="{StaticResource TextBrush}"
              BorderBrush="#44504A"
              FontSize="13"
              FontWeight="Bold"
              Cursor="Hand"
              Visibility="Collapsed"
              Click="StopButton_Click" />
    </Grid>

    <Border Grid.Row="4" Background="#0D1012" BorderBrush="#252B28" BorderThickness="1" CornerRadius="10" Padding="20,17">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="7" Height="7" Fill="#68706C" Margin="0,0,7,0" />
            <TextBlock x:Name="ViewerMetric" Text="观看端离线" Foreground="{StaticResource MutedBrush}" FontSize="11" />
          </StackPanel>
          <TextBlock x:Name="RuntimeState" Text="等待开始" FontSize="15" FontWeight="SemiBold" />
        </DockPanel>
        <TextBlock x:Name="RuntimeDetail" Grid.Row="1" Text="点击开始后直接捕获整个主桌面，不会出现选屏窗口。" Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,20" />
        <Grid Grid.Row="2">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Text="桌面尺寸" Foreground="#68706C" FontSize="10" />
            <TextBlock x:Name="ResolutionMetric" Text="—" FontSize="12" Margin="0,6,0,0" />
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Text="捕获帧率" Foreground="#68706C" FontSize="10" />
            <TextBlock x:Name="FpsMetric" Text="—" FontSize="12" Margin="0,6,0,0" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="NVENC 码率" Foreground="#68706C" FontSize="10" />
            <TextBlock x:Name="BitrateMetric" Text="—" FontSize="12" Margin="0,6,0,0" />
          </StackPanel>
        </Grid>
      </Grid>
    </Border>

    <Grid Grid.Row="5" Margin="0,15,0,0">
      <TextBlock x:Name="SetupError" Foreground="#FF776F" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" />
      <Button x:Name="ResetButton" Content="清除设置" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#68706C" FontSize="11" Cursor="Hand" Padding="8,4" Click="ResetButton_Click" />
    </Grid>
  </Grid>
</Window>
