<Application x:Class="WebScreenCapture.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#08090B" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#111317" />
    <SolidColorBrush x:Key="TextBrush" Color="#F2F5F3" />
    <SolidColorBrush x:Key="MutedBrush" Color="#8B9290" />
    <SolidColorBrush x:Key="AccentBrush" Color="#74F2B8" />

    <Style TargetType="TextBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Background" Value="#0C0E11" />
      <Setter Property="BorderBrush" Value="#343936" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="2,12" />
      <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="PasswordBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Background" Value="#0C0E11" />
      <Setter Property="BorderBrush" Value="#343936" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="2,12" />
      <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>
  </Application.Resources>
</Application>

